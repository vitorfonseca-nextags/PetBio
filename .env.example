# App
NEXT_PUBLIC_APP_URL=            # ex.: https://petbio.com.br
APP_BASE_DOMAIN=petbio.com.br

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # uso só no servidor

# Yampi (checkout)
NEXT_PUBLIC_YAMPI_CHECKOUT_SIMPLES=    # link de compra do produto "PetBio Simples"
NEXT_PUBLIC_YAMPI_CHECKOUT_COMPLETO=   # link de compra do produto "PetBio Completo"

# Yampi (API de administração — só uso local, em script; nunca no app)
YAMPI_MERCHANT_ALIAS=            # Painel Yampi > avatar > Credenciais de API > Alias
YAMPI_USER_TOKEN=                # mesma tela > User Token
YAMPI_USER_SECRET_KEY=           # mesma tela > User Secret Key

# Yampi (webhook)
YAMPI_WEBHOOK_SECRET=           # segredo para validar a assinatura do webhook

# Nextags / n8n (WhatsApp)
NEXTAGS_WEBHOOK_URL=            # endpoint que dispara mensagem no WhatsApp
NEXTAGS_API_TOKEN=              # token de autorização, se aplicável

# Login por código (e-mail), caso use provedor de e-mail
EMAIL_PROVIDER_API_KEY=
