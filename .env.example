# App
NEXT_PUBLIC_APP_URL=            # ex.: https://petbio.cayen.com.br
APP_BASE_DOMAIN=petbio.cayen.com.br

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # uso só no servidor

# Yampi (checkout)
NEXT_PUBLIC_YAMPI_CHECKOUT_SIMPLES=    # link de compra do produto "PetBio Simples"
NEXT_PUBLIC_YAMPI_CHECKOUT_COMPLETO=   # link de compra do produto "PetBio Completo"

# Yampi (API de administração — só uso local, em script; nunca no app)
YAMPI_MERCHANT_ALIAS=            # Painel Yampi > avatar > Credenciais de API > Alias
YAMPI_USER_TOKEN=                # mesma tela > User Token
YAMPI_USER_SECRET_KEY=           # mesma tela > User Secret Key

# Yampi (webhook)
YAMPI_WEBHOOK_SECRET=           # segredo para validar a assinatura do webhook

# NexTags AI (WhatsApp) — ver docs/PLANO.md Fase 5/7.1
NEXTAGS_API_KEY=                     # painel NexTags > Configurações > API
NEXTAGS_FLOW_PREVIA=                 # ID do Flow com o modelo aprovado da prévia
NEXTAGS_FLOW_ENTREGA_APROVADO=       # ID do Flow "pagamento aprovado" (disparado 1º)
NEXTAGS_FLOW_ENTREGA_QR=             # ID do Flow que entrega link + QR (disparado 2º)

# Login por código (e-mail) — provedor: Resend (docs/FASE7.md)
EMAIL_PROVIDER_API_KEY=          # Resend > API Keys > Create API Key
EMAIL_FROM=                      # opcional; sem domínio verificado usa "PetBio <onboarding@resend.dev>"
